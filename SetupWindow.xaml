<ui:FluentWindow x:Class="WindowsLiveCaptionsReader.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="English Learning Assistant"
        Width="500"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Fluent TitleBar (provides drag + close button) -->
        <ui:TitleBar Grid.Row="0"
                     Title="English Learning Assistant"
                     ShowMinimize="False"
                     ShowMaximize="False"/>

        <!-- Main content -->
        <StackPanel Grid.Row="1" Margin="36,8,36,32">

            <!-- App header (icon + subtitle) -->
            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,24">
                <TextBlock Text="🎧" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Configura los modelos de IA antes de comenzar"
                           FontSize="12" Foreground="#888"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- ── WHISPER CARD ─────────────────────────────────────────── -->
            <Border Background="#16FFFFFF" CornerRadius="10" Padding="20" Margin="0,0,0,14">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <TextBlock Text="🗣" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="Transcripción de audio  (Opcional)" Foreground="White"
                                       FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Text="Whisper — requerido solo para captura de audio del sistema"
                                       Foreground="#666" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="Modelo" Foreground="#888" FontSize="11" Margin="0,0,0,6"/>
                    <ComboBox x:Name="WhisperModelCombo"
                                 SelectionChanged="WhisperModelCombo_SelectionChanged"/>

                    <!-- Status area -->
                    <Grid Margin="0,14,0,0">
                        <!-- Ready state -->
                        <StackPanel x:Name="WhisperReadyPanel" Orientation="Horizontal"
                                    Visibility="Collapsed">
                            <TextBlock Text="✅" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="WhisperReadyText" Foreground="#4CAF50"
                                       FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Download progress state -->
                        <StackPanel x:Name="WhisperProgressPanel" Visibility="Collapsed">
                            <ProgressBar x:Name="WhisperProgressBar"
                                         Height="6" Minimum="0" Maximum="100" Value="0"
                                         Margin="0,0,0,6"/>
                            <TextBlock x:Name="WhisperProgressText" Foreground="#AAA"
                                       FontSize="11"/>
                        </StackPanel>

                        <!-- Error state -->
                        <StackPanel x:Name="WhisperErrorPanel" Orientation="Horizontal"
                                    Visibility="Collapsed">
                            <TextBlock Text="❌" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="WhisperErrorText" Foreground="#FF6B6B"
                                       FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Needs download state -->
                        <ui:Button x:Name="WhisperDownloadBtn"
                                   Content="⬇ Descargar modelo"
                                   Click="DownloadWhisper_Click"
                                   Visibility="Collapsed"
                                   HorizontalAlignment="Left"
                                   Appearance="Primary"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── OLLAMA CARD ─────────────────────────────────────────── -->
            <Border Background="#16FFFFFF" CornerRadius="10" Padding="20" Margin="0,0,0,28">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <TextBlock Text="🤖" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="Traducción e inteligencia artificial" Foreground="White"
                                       FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Text="LM Studio — ejecutándose localmente en tu equipo"
                                       Foreground="#666" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Status badge + model selector row -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="LmStudioStatusBadge" Grid.Column="0"
                                CornerRadius="4" Padding="8,4" Margin="0,0,10,0"
                                Background="#22FFFFFF" VerticalAlignment="Center">
                            <TextBlock x:Name="LmStudioStatusBadgeText" Text="⏳ Verificando"
                                       Foreground="#AAA" FontSize="11" FontWeight="SemiBold"/>
                        </Border>

                        <ComboBox x:Name="LmStudioModelCombo" Grid.Column="1"
                                     Margin="0,0,8,0"
                                     SelectionChanged="LmStudioModelCombo_SelectionChanged"
                                     IsEnabled="False"/>

                        <ui:Button Grid.Column="2" Content="↻" Width="36" Height="36"
                                   Click="RefreshLmStudio_Click" Appearance="Secondary"
                                   ToolTip="Reconectar LM Studio"/>
                    </Grid>

                    <TextBlock x:Name="LmStudioHintText"
                               Text="Abre LM Studio y carga un modelo"
                               Foreground="#666" FontSize="11" Margin="0,10,0,0"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <!-- ── START BUTTON ───────────────────────────────────────── -->
            <ui:Button x:Name="StartBtn" Content="Comenzar →"
                       Click="Start_Click" IsEnabled="False"
                       HorizontalAlignment="Stretch"
                       Height="46" FontSize="15" FontWeight="SemiBold"
                       Appearance="Primary"/>

            <TextBlock x:Name="StartHintText"
                       Text=""
                       Foreground="#666" FontSize="11"
                       HorizontalAlignment="Center" Margin="0,10,0,0"/>

        </StackPanel>
    </Grid>
</ui:FluentWindow>
